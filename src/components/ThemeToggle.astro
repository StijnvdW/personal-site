---
const { showLabel = false } = Astro.props;
---

<button class="theme-toggle flex items-center gap-2 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors w-full lg:w-auto" aria-label="Toggle dark mode">
    <div class="relative w-6 h-6">
        <!-- Heroicons v2 Sun (Cleaner variant) -->
        <svg class="sun-icon w-6 h-6 hidden dark:block text-yellow-500 absolute inset-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25V4.5m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M3 12h2.25m.386-6.364 1.591 1.591M16.5 12a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z" />
        </svg>
        <!-- Heroicons v2 Moon -->
        <svg class="moon-icon w-6 h-6 block dark:hidden text-gray-700 absolute inset-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
    </div>
    {showLabel && (
        <span class="text-base/7 dark:text-gray-300">Toggle theme</span>
    )}
</button>

<script>
    const handleToggleClick = () => {
        const element = document.documentElement;
        const isDark = element.getAttribute('data-theme') === 'dark';
        const newTheme = isDark ? 'light' : 'dark';
        
        element.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
    }

    const init = () => {
        const buttons = document.querySelectorAll('.theme-toggle');
        buttons.forEach(button => {
            button.removeEventListener('click', handleToggleClick);
            button.addEventListener('click', handleToggleClick);
        });
    };

    init();
    document.addEventListener('astro:after-swap', init);
</script>

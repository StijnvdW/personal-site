---
const { showLabel = false } = Astro.props;
---

<button class="theme-toggle flex items-center gap-2 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors w-full lg:w-auto" aria-label="Toggle dark mode">
    <div class="relative w-6 h-6">
        <svg class="sun-icon w-6 h-6 hidden dark:block text-yellow-500 absolute inset-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"></path>
        </svg>
        <svg class="moon-icon w-6 h-6 block dark:hidden text-gray-700 absolute inset-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
    </div>
    {showLabel && (
        <span class="text-base/7 dark:text-gray-300">Toggle theme</span>
    )}
</button>

<script>
    const handleToggleClick = () => {
        const element = document.documentElement;
        const isDark = element.getAttribute('data-theme') === 'dark';
        const newTheme = isDark ? 'light' : 'dark';
        
        element.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
    }

    const init = () => {
        const buttons = document.querySelectorAll('.theme-toggle');
        buttons.forEach(button => {
            // Remove existing listener if any (to prevent multiple toggles)
            button.removeEventListener('click', handleToggleClick);
            button.addEventListener('click', handleToggleClick);
        });
    };

    // Run on initial load
    init();

    // Re-run if using Astro's View Transitions
    document.addEventListener('astro:after-swap', init);
</script>
